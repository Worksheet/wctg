<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title><%= it.title %></title>
</head>
<body style="margin:0;padding:0;background:#f5f5f0;font-family:'Courier New',Courier,monospace;font-size:14px;color:#111">

<div style="max-width:700px;margin:24px auto;background:#fff;border:1px solid #ccc;padding:28px 32px">

  <p style="margin:0 0 4px 0;font-size:11px;color:#888;text-transform:uppercase;letter-spacing:0.08em">World Cup Trading Game</p>
  <h1 style="margin:0 0 4px 0;font-size:20px;border-bottom:2px solid #111;padding-bottom:8px">Daily Report</h1>
  <p style="margin:0 0 24px 0;font-size:12px;color:#666"><%= it.dateStr %></p>

  <!-- Trades -->
  <h2 style="margin:0 0 10px 0;font-size:14px;text-transform:uppercase;letter-spacing:0.06em">Recent Trades</h2>
  <% if (!it.trades.length) { %>
  <p style="color:#666;font-size:13px">No trades yet.</p>
  <% } else { %>
  <table style="width:100%;border-collapse:collapse;font-size:13px;margin-bottom:24px">
    <thead>
      <tr style="background:#111;color:#fff">
        <th style="padding:6px 8px;text-align:left">#</th>
        <th style="padding:6px 8px;text-align:left">Writer</th>
        <th style="padding:6px 8px;text-align:left">Counterparty</th>
        <th style="padding:6px 8px;text-align:left">Legs</th>
        <th style="padding:6px 8px;text-align:left">Status</th>
      </tr>
    </thead>
    <tbody>
    <% for (const [i, t] of it.trades.entries()) { %>
    <tr style="background:<%= i % 2 === 0 ? '#fafaf8' : '#fff' %>">
      <td style="padding:5px 8px;border-bottom:1px solid #eee">#<%= t.id %></td>
      <td style="padding:5px 8px;border-bottom:1px solid #eee"><%= t.writer_name %></td>
      <td style="padding:5px 8px;border-bottom:1px solid #eee"><%= t.cp_name %></td>
      <td style="padding:5px 8px;border-bottom:1px solid #eee">
        <% for (const l of t.legs) { %>
        <span style="margin-right:6px;color:<%= l.side === 'BUY' ? '#1a5e1a' : '#800' %>"><%= l.side %> <%= l.quantity %>× <%= l.team_name %><% if (l.leg_type==='cash') { %> £<%= l.cash_amount %><% } %><% if (l.leg_type==='swap') { %> / <%= l.swap_quantity %>× <%= l.swap_team_name %><% } %></span>
        <% } %>
      </td>
      <td style="padding:5px 8px;border-bottom:1px solid #eee">
        <%
          const badgeBg = { pending:'#ffe08a', confirmed:'#c8f5c8', rejected:'#fcc', amended:'#e0e0e0' }[t.status] || '#eee';
          const badgeFg = { pending:'#7a5800', confirmed:'#1a5e1a', rejected:'#800', amended:'#555' }[t.status] || '#333';
        %>
        <span style="background:<%= badgeBg %>;color:<%= badgeFg %>;padding:2px 6px;font-size:11px;font-weight:bold"><%= t.status %></span>
      </td>
    </tr>
    <% } %>
    </tbody>
  </table>
  <% } %>

  <!-- Positions -->
  <h2 style="margin:0 0 10px 0;font-size:14px;text-transform:uppercase;letter-spacing:0.06em">Positions (confirmed trades only)</h2>
  <%
    const nonZeroTeams = it.teams.filter(team => {
      return it.players.some(p => ((it.pos[team.id] || {})[p.id] || 0) !== 0);
    });
  %>
  <% if (!nonZeroTeams.length) { %>
  <p style="color:#666;font-size:13px">No confirmed positions yet.</p>
  <% } else { %>
  <table style="width:100%;border-collapse:collapse;font-size:12px">
    <thead>
      <tr style="background:#111;color:#fff">
        <th style="padding:5px 8px;text-align:left">Team</th>
        <% for (const p of it.players) { %>
        <th style="padding:5px 8px;text-align:center"><%= p.name.split(' ')[0] %></th>
        <% } %>
      </tr>
    </thead>
    <tbody>
    <% for (const [i, team] of nonZeroTeams.entries()) { %>
    <tr style="background:<%= i % 2 === 0 ? '#fafaf8' : '#fff' %>">
      <td style="padding:5px 8px;border-bottom:1px solid #eee"><%= team.name %></td>
      <% for (const p of it.players) { %>
      <% const v = (it.pos[team.id] || {})[p.id] || 0; %>
      <td style="padding:5px 8px;border-bottom:1px solid #eee;text-align:center;font-weight:<%= v !== 0 ? 'bold' : 'normal' %>;color:<%= v > 0 ? '#1a5e1a' : v < 0 ? '#800' : '#ccc' %>"><%= v !== 0 ? v : '·' %></td>
      <% } %>
    </tr>
    <% } %>
    </tbody>
  </table>
  <% } %>

  <p style="margin:28px 0 0 0;font-size:11px;color:#aaa;border-top:1px solid #eee;padding-top:12px">Generated by WCTG · <%= it.dateStr %></p>
</div>

</body>
</html>
